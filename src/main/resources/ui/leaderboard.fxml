<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hu.unideb.inf.strideshifter.controller.LeaderboardController">
    <padding>
        <Insets bottom="30.0" left="50.0" right="50.0" top="30.0" />
    </padding>

    <Label text="Top 10 Leaderboard">
        <font>
            <Font name="System Bold" size="28.0" />
        </font>
    </Label>

    <TableView fx:id="leaderboardTable" prefHeight="400.0" prefWidth="600.0">
        <columns>
            <TableColumn fx:id="playerColumn" prefWidth="250.0" text="Player Name" />
            <TableColumn fx:id="movesColumn" prefWidth="100.0" text="Moves" />
            <TableColumn fx:id="dateColumn" prefWidth="250.0" text="Date &amp; Time" />
        </columns>
    </TableView>

    <Button mnemonicParsing="false" onAction="#backToMenuAction" prefHeight="40.0" prefWidth="200.0" text="Back to Main Menu" />
</VBox>