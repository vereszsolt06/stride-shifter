<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hu.unideb.inf.strideshifter.controller.StrideShifterController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label fx:id="statusLabel" text="Game Starting..." style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <Label fx:id="feedbackLabel" text="" style="-fx-text-fill: red; -fx-font-weight: bold; -fx-font-size: 14px;"/>

    <GridPane fx:id="boardGrid" alignment="CENTER" hgap="2" vgap="2">
    </GridPane>
</VBox>